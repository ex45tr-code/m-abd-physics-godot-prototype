[configuration]
entry_symbol = "m_abd_library_init"
compatibility_minimum = "4.3"

[libraries]
windows.debug.x86_64      = "res://../bin/libmabdphysics.windows.template_debug.x86_64.dll"
windows.release.x86_64    = "res://../bin/libmabdphysics.windows.template_release.x86_64.dll"
linux.debug.x86_64        = "res://../bin/libmabdphysics.linux.template_debug.x86_64.so"
linux.release.x86_64      = "res://../bin/libmabdphysics.linux.template_release.x86_64.so"
macos.debug               = "res://../bin/libmabdphysics.macos.template_debug.universal.dylib"
macos.release             = "res://../bin/libmabdphysics.macos.template_release.universal.dylib"
